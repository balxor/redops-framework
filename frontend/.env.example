# Base URL for the RedOps Framework API.
# Leave as "/api/v1" to use the Vite dev proxy (recommended for local dev).
# For a separately hosted API set the absolute URL, e.g. https://api.redops.example/api/v1
VITE_API_BASE_URL=/api/v1

# Target backend used by the Vite dev proxy (only relevant when VITE_API_BASE_URL is a relative path).
VITE_API_TARGET=http://localhost:8000
