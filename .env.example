REDOPS_APP_NAME=RedOps Framework API
REDOPS_APP_VERSION=0.1.0
REDOPS_ENVIRONMENT=development
REDOPS_API_V1_PREFIX=/api/v1
REDOPS_DATABASE_URL=postgresql+psycopg://redops:redops@postgres:5432/redops
REDOPS_DATABASE_AUTO_CREATE=false
REDOPS_JWT_SECRET_KEY=change-this-development-secret-key-32-bytes-minimum
REDOPS_ACCESS_TOKEN_EXPIRE_MINUTES=60
REDOPS_BOOTSTRAP_ADMIN_ENABLED=true
REDOPS_BOOTSTRAP_ADMIN_EMAIL=admin@example.com
REDOPS_BOOTSTRAP_ADMIN_PASSWORD=admin-change-me
REDOPS_BOOTSTRAP_ADMIN_FULL_NAME=RedOps Admin
